# OSeer configuration — copy to .env and adjust for your self-hosted model server.

# --- Model API (OpenAI-compatible Chat Completions) ---
# Point this at YOUR server. Common self-hosted defaults:
#   vLLM    ->  http://localhost:8000/v1
#   SGLang  ->  http://localhost:30000/v1
#   Ollama  ->  http://localhost:11434/v1
OSEER_API_BASE=http://localhost:8000/v1

# Model id EXACTLY as your server exposes it (e.g. what you passed to --served-model-name).
OSEER_MODEL=Qwen/Qwen-AgentWorld-35B-A3B

# API key is OPTIONAL for self-hosted servers — leave blank if your server needs no auth.
# (FRIENDLI_TOKEN is also accepted as a fallback for hosted providers.)
OSEER_API_KEY=

# --- Sampling (defaults from the model card) ---
OSEER_TEMPERATURE=0.6
OSEER_TOP_P=0.95
OSEER_TOP_K=20
OSEER_MAX_TOKENS=2048
# <think> reasoning mode: slower but higher quality. Off by default.
OSEER_REASONING=false
OSEER_REASONING_MAX_TOKENS=8192

# --- Server-compatibility toggles (all safe for vLLM/SGLang) ---
# Force syntactically valid JSON when not reasoning (response_format=json_object):
OSEER_JSON_MODE=true
# Send top_k (a sampling extension vLLM/SGLang accept):
OSEER_SEND_TOP_K=true
# Send chat_template_kwargs.enable_thinking to control <think> per request:
OSEER_SEND_THINKING_FLAG=true

# --- Behavior ---
OSEER_TIMEOUT=60
OSEER_RETRIES=2
OSEER_ENV_TTL=60
# Environment grounding depth sent to the model: full | minimal | none
OSEER_GROUNDING=full
OSEER_CACHE_SIZE=256
